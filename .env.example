# LLM API 配置（兼容 OpenAI API 格式）
# 小米预训练基础大模型或其他兼容 API
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.xiaomi.com/v1
LLM_MODEL_NAME=xiaomi-pretrained-base

# 嵌入模型配置（用于 RAG 向量化）
EMBEDDING_API_KEY=your-embedding-api-key-here
EMBEDDING_BASE_URL=https://api.xiaomi.com/v1
EMBEDDING_MODEL_NAME=xiaomi-embedding

# Agent 配置
AGENT_MAX_ITERATIONS=10
AGENT_VERBOSE=true
